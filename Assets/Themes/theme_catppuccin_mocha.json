{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(30, 30, 46, 0.95)",
        "border": "1px solid #313244",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 200],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(49, 50, 68, 0.95)",
        "text_color": "#cdd6f4",
        "border": "1px solid #45475a",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#cdd6f4",
        "selected_background": "#cba6f7",
        "selected_text_color": "#1e1e2e",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(88, 91, 112, 0.6)",
        "handle_hover_color": "rgba(88, 91, 112, 0.9)",
        "border_radius": "3px"
    }
}