{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(0, 43, 54, 0.95)",
        "border": "1px solid #073642",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 180],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(7, 54, 66, 0.95)",
        "text_color": "#839496",
        "border": "1px solid #586e75",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#839496",
        "selected_background": "#2aa198",
        "selected_text_color": "#002b36",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(88, 110, 117, 0.4)",
        "handle_hover_color": "rgba(88, 110, 117, 0.8)",
        "border_radius": "3px"
    }
}