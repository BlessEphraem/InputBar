{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(43, 33, 58, 0.95)",
        "border": "1px solid #413259",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 220],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(54, 42, 73, 0.95)",
        "text_color": "#fdfdfd",
        "border": "1px solid #f92aad",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#fdfdfd",
        "selected_background": "#36f9f6",
        "selected_text_color": "#2b213a",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(249, 42, 173, 0.6)",
        "handle_hover_color": "rgba(249, 42, 173, 0.9)",
        "border_radius": "3px"
    }
}