{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(240, 240, 240, 0.95)",
        "border": "1px solid #ccc",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 50],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(255, 255, 255, 1.0)",
        "text_color": "#333333",
        "border": "1px solid #aaa",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#333333",
        "selected_background": "rgba(0, 120, 212, 1.0)",
        "selected_text_color": "white",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(180, 180, 180, 0.6)",
        "handle_hover_color": "rgba(150, 150, 150, 0.8)",
        "border_radius": "3px"
    }
}