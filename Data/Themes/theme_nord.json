{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(46, 52, 64, 0.95)",
        "border": "1px solid #3b4252",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 150],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(59, 66, 82, 0.95)",
        "text_color": "#d8dee9",
        "border": "1px solid #4c566a",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#d8dee9",
        "selected_background": "#88c0d0",
        "selected_text_color": "#2e3440",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(76, 86, 106, 0.6)",
        "handle_hover_color": "rgba(76, 86, 106, 0.9)",
        "border_radius": "3px"
    }
}