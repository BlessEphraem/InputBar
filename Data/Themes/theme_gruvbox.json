{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(40, 40, 40, 0.95)",
        "border": "1px solid #3c3836",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 180],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(60, 56, 54, 0.95)",
        "text_color": "#ebdbb2",
        "border": "1px solid #504945",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#ebdbb2",
        "selected_background": "#fabd2f",
        "selected_text_color": "#282828",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(102, 92, 84, 0.6)",
        "handle_hover_color": "rgba(102, 92, 84, 0.9)",
        "border_radius": "3px"
    }
}