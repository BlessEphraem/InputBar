{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(41, 45, 62, 0.95)",
        "border": "1px solid #3b3f51",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 180],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(59, 63, 81, 0.95)",
        "text_color": "#bfc7d5",
        "border": "1px solid #676e95",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#bfc7d5",
        "selected_background": "#82aaff",
        "selected_text_color": "#292d3e",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(103, 110, 149, 0.6)",
        "handle_hover_color": "rgba(103, 110, 149, 0.9)",
        "border_radius": "3px"
    }
}