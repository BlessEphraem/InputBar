{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(0, 0, 0, 1.0)",
        "border": "2px solid #ffffff",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 0],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(0, 0, 0, 1.0)",
        "text_color": "#ffffff",
        "border": "2px solid #ffffff",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#ffffff",
        "selected_background": "#ffffff",
        "selected_text_color": "#000000",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(255, 255, 255, 1.0)",
        "handle_hover_color": "rgba(255, 255, 255, 1.0)",
        "border_radius": "3px"
    }
}