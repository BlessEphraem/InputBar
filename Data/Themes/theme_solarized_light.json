{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(253, 246, 227, 0.95)",
        "border": "1px solid #eee8d5",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 40],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(238, 232, 213, 0.95)",
        "text_color": "#657b83",
        "border": "1px solid #93a1a1",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#657b83",
        "selected_background": "#268bd2",
        "selected_text_color": "#fdf6e3",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(147, 161, 161, 0.4)",
        "handle_hover_color": "rgba(147, 161, 161, 0.8)",
        "border_radius": "3px"
    }
}