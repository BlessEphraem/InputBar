{
    "window": {
        "width": 620,
        "height": 500,
        "margin": 50
    },
    "container": {
        "background": "rgba(239, 241, 245, 0.95)",
        "border": "1px solid #ccd0da",
        "border_radius": "8px",
        "shadow_color": [0, 0, 0, 40],
        "shadow_blur": 25,
        "shadow_x_offset": 0,
        "shadow_y_offset": 5,
        "padding": 10,
        "spacing": 8
    },
    "search_bar": {
        "background": "rgba(204, 208, 218, 0.95)",
        "text_color": "#4c4f69",
        "border": "1px solid #bcc0cc",
        "border_radius": "4px",
        "padding": "12px",
        "font_size": "18px",
        "font_family": "Segoe UI",
        "placeholder": "Search..."
    },
    "results_list": {
        "background": "transparent",
        "text_color": "#4c4f69",
        "selected_background": "#209fb5",
        "selected_text_color": "#eff1f5",
        "font_size": "15px",
        "font_family": "Segoe UI",
        "item_padding": "8px",
        "item_border_radius": "4px",
        "height": 350
    },
    "scrollbar": {
        "width": "0px",
        "background": "transparent",
        "handle_color": "rgba(140, 143, 161, 0.4)",
        "handle_hover_color": "rgba(140, 143, 161, 0.7)",
        "border_radius": "3px"
    }
}